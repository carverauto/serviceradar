load("//build:mix_release.bzl", "mix_release")
load("@rules_shell//shell:sh_test.bzl", "sh_test")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "srcs",
    srcs = glob(
        ["**"],
        exclude = [
            "bazel-*",
            "_build/**",
            "assets/**/target/**",
            "deps/**",
            "native/**/target/**",
            "node_modules/**",
            "tmp/**",
            ".git/**",
        ],
    ),
)

filegroup(
    name = "deps_srcs",
    srcs = [
        "mix.exs",
        "mix.lock",
    ] + glob(["config/**"]),
)

genrule(
    name = "precommit_runner",
    srcs = ["scripts/bazel_precommit.sh"],
    outs = ["precommit_runner.sh"],
    cmd = "/bin/cp $(location scripts/bazel_precommit.sh) $@ && /bin/chmod +x $@",
    local = True,
)

genrule(
    name = "precommit_test_runner",
    srcs = ["scripts/bazel_precommit_test.sh"],
    outs = ["precommit_test_runner.sh"],
    cmd = "/bin/cp $(location scripts/bazel_precommit_test.sh) $@ && /bin/chmod +x $@",
    local = True,
)

sh_test(
    name = "precommit",
    srcs = [":precommit_test_runner"],
    data = [
        ":precommit_runner",
        "//build:mix_release_patches.py",
        ":srcs",
        "//:Cargo.toml",
        "//:Cargo.lock",
        "//:.tool-versions",
        "//:elixir/.credo.base.exs",
        "//:elixir/.credo.ex_dna.exs",
        "//:elixir/.credo.ex_slop.exs",
        "//proto:kv_proto_src",
        "//rust/kvutil:srcs",
        "//rust/srql:srcs",
        "//elixir/connection:srcs",
        "//elixir/elixir_uuid:srcs",
        "//elixir/serviceradar_core:srcs",
        "//elixir/serviceradar_srql:srcs",
        "//elixir/datasvc:srcs",
        "//elixir/vendor/opentelemetry_oban:srcs",
    ],
    local = True,
    tags = [
        "no-remote",
        "no-sandbox",
    ],
    timeout = "eternal",
)

mix_release(
    name = "release_tar",
    srcs = [":srcs"],
    bootstrap_srcs = [":deps_srcs"],
    out = "serviceradar-web-ng-release.tar.gz",
    src_dir = "elixir/web-ng",
    extra_dirs = [
        "elixir/connection",
        "elixir/elixir_uuid",
        "elixir/serviceradar_core",
        "elixir/serviceradar_srql",
        "elixir/vendor/opentelemetry_oban",
        "proto",
        "rust/srql",
        "rust/kvutil",
        "elixir/datasvc",
    ],
    extra_dir_srcs = [
        "//elixir/connection:srcs",
        "//elixir/elixir_uuid:srcs",
        "//elixir/serviceradar_core:srcs",
        "//elixir/serviceradar_srql:srcs",
        "//elixir/vendor/opentelemetry_oban:srcs",
        "//proto:kv_proto_src",
        "//rust/srql:srcs",
        "//rust/kvutil:srcs",
        "//elixir/datasvc:srcs",
    ],
    bun = "@bun_linux_amd64//:bun",
    workdir_name = "serviceradar_web_ng",
)
