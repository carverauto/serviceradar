{
  "type": "object",
  "properties": {
    "host": {
      "type": "string",
      "description": "AXIS camera host or IP"
    },
    "scheme": {
      "type": "string",
      "description": "http or https",
      "default": "http"
    },
    "username": {
      "type": "string",
      "description": "Camera API username"
    },
    "password_secret_ref": {
      "type": "string",
      "description": "Secret reference for the camera API password",
      "secretRef": true
    },
    "stream_auth_mode": {
      "type": "string",
      "description": "Expected RTSP stream authentication mode",
      "default": "unknown",
      "enum": ["none", "basic", "digest", "unknown"]
    },
    "timeout": {
      "type": "string",
      "description": "Request timeout duration",
      "default": "10s"
    },
    "discover_streams": {
      "type": "boolean",
      "description": "Attempt stream profile/status discovery",
      "default": true
    },
    "collect_events": {
      "type": "boolean",
      "description": "Collect camera events from VAPIX websocket stream",
      "default": false
    },
    "event_topic_filters": {
      "type": "string",
      "description": "Comma or newline separated VAPIX topic filters for websocket events"
    },
    "event_sources": {
      "type": "string",
      "description": "VAPIX websocket sources query string value",
      "default": "events"
    }
  },
  "required": ["host"]
}
