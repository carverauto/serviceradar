{
  "type": "object",
  "properties": {
    "host": {
      "type": "string",
      "description": "AXIS camera host or IP"
    },
    "scheme": {
      "type": "string",
      "description": "http or https",
      "default": "http"
    },
    "username": {
      "type": "string",
      "description": "Camera API username"
    },
    "password": {
      "type": "string",
      "description": "Camera API password"
    },
    "timeout": {
      "type": "string",
      "description": "Request timeout duration",
      "default": "10s"
    },
    "relay": {
      "type": "object",
      "description": "Injected relay session context from the agent streaming runtime"
    }
  },
  "required": ["host"]
}
