{
  "plugin_id": "axis-camera",
  "name": "AXIS Camera",
  "version": "0.1.0",
  "description": "Collects AXIS VAPIX camera health, inventory and stream metadata",
  "entrypoint": "run_check",
  "runtime": "wasi-preview1",
  "outputs": "serviceradar.plugin_result.v1",
  "capabilities": [
    "get_config",
    "log",
    "submit_result",
    "http_request",
    "websocket_connect",
    "websocket_send",
    "websocket_recv",
    "websocket_close"
  ],
  "permissions": {
    "allowed_domains": ["*"],
    "allowed_ports": [80, 443, 554]
  },
  "resources": {
    "requested_memory_mb": 64,
    "max_open_connections": 2
  },
  "params_schema": {
    "type": "object",
    "properties": {
      "host": {
        "type": "string",
        "description": "AXIS camera host or IP"
      },
      "scheme": {
        "type": "string",
        "description": "http or https",
        "default": "http"
      },
      "username": {
        "type": "string",
        "description": "Camera API username"
      },
      "password": {
        "type": "string",
        "description": "Camera API password"
      },
      "timeout": {
        "type": "string",
        "description": "Request timeout duration",
        "default": "10s"
      },
      "discover_streams": {
        "type": "boolean",
        "description": "Attempt stream profile/status discovery",
        "default": true
      },
      "collect_events": {
        "type": "boolean",
        "description": "Collect camera events from VAPIX websocket stream",
        "default": false
      },
      "event_sources": {
        "type": "string",
        "description": "VAPIX websocket sources query string value",
        "default": "events"
      }
    },
    "required": ["host"]
  }
}
