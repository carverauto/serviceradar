{
  "plugin_id": "unifi-protect-camera-stream",
  "name": "UniFi Protect Camera Stream",
  "version": "0.1.0",
  "description": "Streams UniFi Protect camera media through the ServiceRadar media host bridge",
  "entrypoint": "stream_camera",
  "runtime": "wasi-preview1",
  "outputs": "serviceradar.camera_stream.v1",
  "capabilities": [
    "get_config",
    "log",
    "camera_media_stream",
    "http_request",
    "tcp_connect",
    "tcp_read",
    "tcp_write",
    "tcp_close"
  ],
  "permissions": {
    "allowed_domains": ["*"],
    "allowed_ports": [80, 443, 7447, 7441]
  },
  "resources": {
    "requested_memory_mb": 64,
    "max_open_connections": 1
  },
  "params_schema": {
    "type": "object",
    "properties": {
      "host": {
        "type": "string",
        "description": "UniFi Protect controller host or IP"
      },
      "scheme": {
        "type": "string",
        "description": "http or https",
        "default": "https"
      },
      "username": {
        "type": "string",
        "description": "Protect local account username"
      },
      "password": {
        "type": "string",
        "description": "Protect local account password"
      },
      "api_key": {
        "type": "string",
        "description": "Optional Protect API key"
      },
      "cookie": {
        "type": "string",
        "description": "Optional pre-provisioned controller Cookie header value"
      },
      "timeout": {
        "type": "string",
        "description": "Request timeout duration",
        "default": "10s"
      },
      "insecure_skip_verify": {
        "type": "boolean",
        "description": "Allow self-signed or otherwise untrusted TLS certificates for controller APIs and RTSPS stream transport",
        "default": false
      },
      "bootstrap_path": {
        "type": "string",
        "description": "Protect bootstrap path",
        "default": "/proxy/protect/api/bootstrap"
      },
      "login_path": {
        "type": "string",
        "description": "UniFi OS login path",
        "default": "/api/auth/login"
      },
      "rtsp_port": {
        "type": "integer",
        "description": "Protect RTSP relay port",
        "default": 7447
      },
      "relay": {
        "type": "object",
        "description": "Injected relay session context from the agent streaming runtime"
      }
    },
    "required": ["host"]
  }
}
