{
  "plugin_id": "unifi-protect-camera",
  "name": "UniFi Protect Camera",
  "version": "0.1.0",
  "description": "Collects UniFi Protect camera inventory and stream metadata",
  "entrypoint": "run_check",
  "runtime": "wasi-preview1",
  "outputs": "serviceradar.plugin_result.v1",
  "capabilities": [
    "get_config",
    "log",
    "submit_result",
    "http_request",
    "websocket_connect",
    "websocket_recv",
    "websocket_close"
  ],
  "permissions": {
    "allowed_domains": ["*"],
    "allowed_ports": [80, 443, 7447]
  },
  "resources": {
    "requested_memory_mb": 64,
    "max_open_connections": 2
  },
  "params_schema": {
    "type": "object",
    "properties": {
      "host": {
        "type": "string",
        "description": "UniFi Protect controller host or IP"
      },
      "scheme": {
        "type": "string",
        "description": "http or https",
        "default": "https"
      },
      "username": {
        "type": "string",
        "description": "Protect local account username"
      },
      "password": {
        "type": "string",
        "description": "Protect local account password"
      },
      "api_key": {
        "type": "string",
        "description": "Optional Protect API key"
      },
      "cookie": {
        "type": "string",
        "description": "Optional pre-provisioned controller Cookie header value"
      },
      "timeout": {
        "type": "string",
        "description": "Request timeout duration",
        "default": "10s"
      },
      "discover_streams": {
        "type": "boolean",
        "description": "Discover RTSP stream profiles from bootstrap",
        "default": true
      },
      "collect_events": {
        "type": "boolean",
        "description": "Collect a bounded Protect websocket event sample",
        "default": false
      },
      "event_sources": {
        "type": "string",
        "description": "Protect event source selector; current plugin uses the updates feed",
        "default": "updates"
      },
      "bootstrap_path": {
        "type": "string",
        "description": "Protect bootstrap path",
        "default": "/proxy/protect/api/bootstrap"
      },
      "login_path": {
        "type": "string",
        "description": "UniFi OS login path",
        "default": "/api/auth/login"
      },
      "rtsp_port": {
        "type": "integer",
        "description": "Protect RTSP relay port",
        "default": 7447
      }
    },
    "required": ["host"]
  }
}
