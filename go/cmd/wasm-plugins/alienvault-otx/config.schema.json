{
  "type": "object",
  "properties": {
    "base_url": {
      "type": "string",
      "description": "AlienVault OTX base URL",
      "default": "https://otx.alienvault.com"
    },
    "api_key_secret_ref": {
      "type": "string",
      "description": "AlienVault OTX API key",
      "secretRef": true
    },
    "modified_since": {
      "type": "string",
      "description": "Optional OTX modified_since cursor"
    },
    "types": {
      "type": "string",
      "description": "Comma-delimited OTX indicator types to fetch",
      "default": "IPv4,IPv6,CIDR"
    },
    "limit": {
      "type": "integer",
      "description": "OTX page size",
      "minimum": 1,
      "maximum": 1000,
      "default": 1000
    },
    "page": {
      "type": "integer",
      "description": "OTX page number",
      "minimum": 1,
      "default": 1
    },
    "timeout_ms": {
      "type": "integer",
      "description": "Request timeout in milliseconds",
      "minimum": 1000,
      "maximum": 600000,
      "default": 120000
    },
    "max_pages": {
      "type": "integer",
      "description": "Maximum OTX pages fetched in one plugin run",
      "minimum": 1,
      "maximum": 10000,
      "default": 500
    },
    "max_indicators": {
      "type": "integer",
      "description": "Maximum normalized indicators emitted in one plugin run",
      "minimum": 1,
      "maximum": 500000,
      "default": 50000
    },
    "max_retries": {
      "type": "integer",
      "description": "Retry attempts for transient OTX page fetch failures",
      "minimum": 0,
      "maximum": 5,
      "default": 3
    },
    "backoff_ms": {
      "type": "integer",
      "description": "Base retry backoff in milliseconds",
      "minimum": 100,
      "maximum": 30000,
      "default": 1000
    }
  },
  "required": ["api_key_secret_ref"]
}
