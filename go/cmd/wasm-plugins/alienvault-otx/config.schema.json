{
  "type": "object",
  "properties": {
    "base_url": {
      "type": "string",
      "description": "AlienVault OTX base URL",
      "default": "https://otx.alienvault.com"
    },
    "api_key_secret_ref": {
      "type": "string",
      "description": "AlienVault OTX API key",
      "secretRef": true
    },
    "modified_since": {
      "type": "string",
      "description": "Optional OTX modified_since cursor"
    },
    "limit": {
      "type": "integer",
      "description": "OTX page size",
      "minimum": 1,
      "maximum": 100,
      "default": 10
    },
    "page": {
      "type": "integer",
      "description": "OTX page number",
      "minimum": 1,
      "default": 1
    },
    "timeout_ms": {
      "type": "integer",
      "description": "Request timeout in milliseconds",
      "minimum": 1000,
      "maximum": 120000,
      "default": 20000
    },
    "max_indicators": {
      "type": "integer",
      "description": "Maximum normalized indicators emitted in one plugin result",
      "minimum": 1,
      "maximum": 5000,
      "default": 2000
    }
  },
  "required": ["api_key_secret_ref"]
}
