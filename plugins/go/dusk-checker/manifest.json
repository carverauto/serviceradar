{
  "plugin_id": "dusk-checker",
  "name": "Dusk Checker",
  "version": "1.0.0",
  "description": "Monitors Dusk blockchain nodes via WebSocket API",
  "entrypoint": "run_check",
  "runtime": "wasi-preview1",
  "outputs": "serviceradar.plugin_result.v1",
  "capabilities": [
    "get_config",
    "log",
    "submit_result",
    "websocket_connect",
    "websocket_send",
    "websocket_recv",
    "websocket_close"
  ],
  "permissions": {
    "allowed_domains": ["*"],
    "allowed_ports": [8080, 443, 9000]
  },
  "resources": {
    "requested_memory_mb": 64,
    "max_open_connections": 1
  },
  "params_schema": {
    "type": "object",
    "properties": {
      "node_address": {
        "type": "string",
        "description": "WebSocket endpoint of the Dusk node (e.g., localhost:8080)"
      },
      "timeout": {
        "type": "string",
        "description": "Connection timeout duration (e.g., 30s, 1m)",
        "default": "30s"
      }
    },
    "required": ["node_address"]
  }
}
