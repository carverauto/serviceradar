{
  "listen_addr": "0.0.0.0:5353",
  "buffer_size": 65536,
  "multicast_groups": ["224.0.0.251"],
  "nats_url": "tls://serviceradar-nats:4222",
  "nats_creds_file": "/etc/serviceradar/creds/platform.creds",
  "stream_name": "events",
  "subject": "discovery.raw.mdns",
  "stream_subjects": [
    "discovery.raw.mdns",
    "discovery.raw.mdns.processed"
  ],
  "stream_max_bytes": 10737418240,
  "partition": "default",
  "channel_size": 10000,
  "batch_size": 100,
  "publish_timeout_ms": 5000,
  "drop_policy": "drop_oldest",
  "dedup_ttl_secs": 300,
  "dedup_max_entries": 100000,
  "dedup_cleanup_interval_secs": 60,
  "security": {
    "mode": "mtls",
    "cert_dir": "/etc/serviceradar/certs",
    "tls": {
      "cert_file": "mdns-client.crt",
      "key_file": "mdns-client.key",
      "ca_file": "ca.crt"
    }
  },
  "metrics_addr": "0.0.0.0:50047"
}
