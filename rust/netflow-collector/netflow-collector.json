{
  "listen_addr": "0.0.0.0:2055",
  "buffer_size": 65536,
  "nats_url": "tls://serviceradar-nats:4222",
  "nats_creds_file": "/etc/serviceradar/creds/platform.creds",
  "stream_name": "events",
  "subject": "flows.raw.netflow",
  "stream_subjects": [
    "flows.raw.netflow",
    "flows.raw.netflow.processed"
  ],
  "stream_max_bytes": 10737418240,
  "partition": "default",
  "channel_size": 10000,
  "batch_size": 100,
  "publish_timeout_ms": 5000,
  "drop_policy": "drop_oldest",
  "security": {
    "mode": "mtls",
    "cert_dir": "/etc/serviceradar/certs",
    "tls": {
      "cert_file": "netflow-client.crt",
      "key_file": "netflow-client.key",
      "ca_file": "ca.crt"
    }
  },
  "pending_flows": {
    "max_pending_flows": 256,
    "max_entries_per_template": 1024,
    "max_entry_size_bytes": 65535,
    "ttl_secs": 300
  },
  "metrics_addr": "0.0.0.0:50046"
}
