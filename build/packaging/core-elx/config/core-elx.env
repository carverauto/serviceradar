# ServiceRadar core-elx runtime environment
# Fill in real values before starting the service.
RELEASE_NODE=serviceradar_core_elx@127.0.0.1
RELEASE_COOKIE=serviceradar

# Database
DATABASE_URL=postgres://serviceradar:serviceradar@localhost:5432/serviceradar
CNPG_HOST=localhost
CNPG_PORT=5432
CNPG_USERNAME=serviceradar
CNPG_PASSWORD=serviceradar
CNPG_DATABASE=serviceradar

# NATS (set to true when nats-server is available)
NATS_ENABLED=false
NATS_URL=nats://localhost:4222

# Clustering (disable for single-node bare-metal)
CLUSTER_ENABLED=false

# Encryption key for AshCloak (generate with: mix phx.gen.secret 32 | head -c 32 | base64)
# CLOAK_KEY=

# Status handler for agent-gateway push results
STATUS_HANDLER_ENABLED=true
