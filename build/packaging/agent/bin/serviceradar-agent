#!/bin/sh
set -eu

RUNTIME_ROOT="${SERVICERADAR_AGENT_RUNTIME_ROOT:-/var/lib/serviceradar/agent}"
SEED_BINARY="${SERVICERADAR_AGENT_SEED_BINARY:-/usr/local/lib/serviceradar/agent/serviceradar-agent-seed}"
VERSIONS_DIR="${RUNTIME_ROOT}/versions"
SEED_DIR="${VERSIONS_DIR}/seed-installed"
CURRENT_LINK="${RUNTIME_ROOT}/current"

mkdir -p "${VERSIONS_DIR}" "${RUNTIME_ROOT}/tmp"

if [ ! -e "${CURRENT_LINK}" ]; then
    mkdir -p "${SEED_DIR}"
    if [ ! -x "${SEED_DIR}/serviceradar-agent" ]; then
        cp "${SEED_BINARY}" "${SEED_DIR}/serviceradar-agent"
        chmod 0755 "${SEED_DIR}/serviceradar-agent"
    fi

    ln -sfn "versions/seed-installed" "${CURRENT_LINK}.new"
    mv -Tf "${CURRENT_LINK}.new" "${CURRENT_LINK}"
fi

exec "${CURRENT_LINK}/serviceradar-agent" "$@"
