# ServiceRadar agent-gateway runtime environment
# Fill in real values before starting the service.
RELEASE_NODE=serviceradar_agent_gateway@127.0.0.1
RELEASE_COOKIE=serviceradar

# Agent-gateway does not connect to the database directly by default
SERVICERADAR_CORE_REPO_ENABLED=false

# NATS (set to true when nats-server is available)
NATS_ENABLED=false
NATS_URL=nats://localhost:4222

# Clustering (disable for single-node bare-metal)
CLUSTER_ENABLED=false

# gRPC listen address for agent connections
GRPC_LISTEN_ADDRESS=0.0.0.0:50052
